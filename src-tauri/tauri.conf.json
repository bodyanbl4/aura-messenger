{
  "productName": "Aura",
  "version": "1.0.0",
  "identifier": "com.aura.messenger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aura Messenger",
        "width": 1280,
        "height": 850,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Russian"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "both"
      }
    }
  }
}